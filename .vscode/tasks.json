{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build CLI (Go)",
            "type": "shell",
            "command": "go build -o odc ./cmd/odc/",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$go"
            ]
        },
        {
            "label": "Build CLI (Just)",
            "type": "shell",
            "command": "just build",
            "group": "build",
            "problemMatcher": [
                "$go"
            ]
        },
        {
            "label": "Test All",
            "type": "shell",
            "command": "go test ./...",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$go"
            ]
        }
    ]
}
