{
  "release-type": "go",
  "prerelease": false,
  "packages": {
    ".": {
      "type": "go",
      "extra-files": [
        "internal/version/version.go",
        {
          "type": "json",
          "path": ".github/prerelease-manifest.json",
          "jsonpath": "$[\".\"]"
        }
      ]
    }
  }
}
